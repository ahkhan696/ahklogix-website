# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=AHKLOGIX
APP_ENV=production
APP_KEY=                          # run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://ahklogix.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                   # 'debug' locally, 'error' on production

# ─── Database (MySQL — Hostinger hPanel credentials) ──────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1                 # Hostinger internal host (from hPanel > Databases)
DB_PORT=3306
DB_DATABASE=your_db_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ─── Cache / Session / Queue ──────────────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# QUEUE_CONNECTION=sync means jobs run immediately in the same request.
# Correct for shared hosting — no queue worker is available.
# Mail is sent synchronously; media conversions use .nonQueued().
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

BROADCAST_CONNECTION=log

# ─── Mail (Hostinger SMTP) ────────────────────────────────────────────────────
# Create an email account in hPanel (e.g. contact@ahklogix.com),
# then use those credentials here.
MAIL_MAILER=smtp
MAIL_SCHEME=ssl
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=contact@ahklogix.com   # the Hostinger email account
MAIL_PASSWORD=                        # the email account password
MAIL_FROM_ADDRESS=contact@ahklogix.com
MAIL_FROM_NAME="AHKLOGIX"

# The contact form sends notification emails to the address stored in
# Settings > contact_email (editable in /admin). MAIL_FROM_ADDRESS is used
# as a fallback if that setting is empty.

# ─── AI Chatbot ───────────────────────────────────────────────────────────────
# CHAT_DRIVER: gemini (default, free tier) | claude (paid) | rules (no API)
CHAT_DRIVER=gemini

# Google Gemini — free tier, no credit card required
# Get key at: aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-flash-latest

# Anthropic Claude — paid (prepaid credits, no subscription)
# Get key at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001

# ─── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
